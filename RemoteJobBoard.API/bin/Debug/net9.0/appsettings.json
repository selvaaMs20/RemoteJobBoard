{
  "ConnectionStrings": {
    "DefaultConnection": "Server=AKHILDEV;Database=RemoteJobBoardDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
            "outputTemplate": "[{Timestamp:dd-MM HH:mm:ss} {Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      },
      { "Name": "File", "Args": { "path": "logs/remotejobboard.log", "rollingInterval": "Day", "rollOnFileSizeLimit": true } }
    ]
  },
  "AllowedHosts": "*"
}
